{
  "domain": "linear_equation",
  "unit_title": "一次方程式",
  "lesson_goals": [
    {
      "goal_id": "transpose_terms",
      "target_skill": "can_transpose_terms",
      "goal_text": "移項すると符号が変わることを理解する",
      "success_criteria": [
        "x + b = c 型で定数項を正しく移項できる",
        "反対側へ移すと符号が変わる理由を短く説明できる"
      ]
    },
    {
      "goal_id": "divide_by_coefficient",
      "target_skill": "can_divide_by_coefficient",
      "goal_text": "係数で両辺を割って x を求める",
      "success_criteria": [
        "ax = b 型で両辺を a で割れる",
        "3x = 15 のような式で 3 を引く誤りを避けられる"
      ]
    },
    {
      "goal_id": "negative_numbers",
      "target_skill": "can_handle_negative_numbers",
      "goal_text": "負の数を含む一次方程式を解く",
      "success_criteria": [
        "負の係数で割るときの符号を正しく扱える",
        "定数項の移項と負号を区別できる"
      ]
    },
    {
      "goal_id": "fractions",
      "target_skill": "can_handle_fractions",
      "goal_text": "分数を含む一次方程式を解く",
      "success_criteria": [
        "分母を払う手順を選べる",
        "両辺に同じ数をかける操作を説明できる"
      ]
    },
    {
      "goal_id": "solve_ax_plus_b_equals_c",
      "target_skill": "can_solve_ax_plus_b_equals_c",
      "goal_text": "ax + b = c 型の一次方程式を自力で解く",
      "success_criteria": [
        "移項と係数で割る操作を順番に使える",
        "求めた x を元の式に代入して確認できる"
      ]
    }
  ],
  "skill_priority": [
    "can_transpose_terms",
    "can_divide_by_coefficient",
    "can_handle_negative_numbers",
    "can_handle_fractions",
    "can_solve_ax_plus_b_equals_c"
  ],
